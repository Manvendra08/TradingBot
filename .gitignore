# NSEBOT — git ignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environment (keep only .venv)
venv/
.venv/
.venv-*/
.venv_new/
env/

# Environment / secrets
.env
*.env.local

# SQLite database (local data — don't commit)
data/*.db
data/*.db-shm
data/*.db-wal

# Logs
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Streamlit
.streamlit/

# Test coverage artifacts — never commit these
.coverage
coverage.xml
htmlcov/
.pytest_cache/

# Cleanup backups
cleanup_backup_*/
backup_safe_delete_*/

# Scratch directory (keep folder, ignore contents)
scratch/*
!scratch/.gitkeep

# Cache directories (keep only active yf-cache)
data/yf-cache[2-9]/
data/yf-cache[0-9][0-9]/

# Database backups and journals
data/*.backup
data/*.db-journal

# Debug outputs and screenshots
*.png
paper_out.html

# Archive files
*.zip

# Local backups & large data
Backup/
Proceeding without questions/
data/dhan_scrip_master.csv
.kiro/

# Backup codebase snapshot (full project copy)
Codebase/

# Runtime state files
data/ip_state.json
data/runtime_config.json

# ML model artifacts
data/models/

# Broker token caches
shoonya_shared_token.json

# Coverage data
.coverage
