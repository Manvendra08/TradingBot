
# Environment variables for NSEBOT
# Copy this to .env and fill in your values.
# Load with: pip install python-dotenv  →  from dotenv import load_dotenv; load_dotenv()
# Or set in your system environment before running.

# ── Dhan ───────────────────────────────────────────────────────────────────
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# ── Upstox ─────────────────────────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=your_upstox_access_token

# ── Telegram ───────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather → get BOT_TOKEN
# 2. Send a message to your bot, then call:
#    https://api.telegram.org/bot<BOT_TOKEN>/getUpdates  → find chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Discord ────────────────────────────────────────────────────────────────
# Discord Incoming Webhook URL to send alert messages to a channel
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ── TradingView (optional — Shoonya is now the primary chart source) ─────────
# Shoonya GetTimePriceSeries provides exchange-native INR OHLC for all symbols
# (NSE/BSE indices via static tokens, MCX via SearchScrip). TV credentials are
# only used as a tertiary fallback if you still want tvDatafeed.
#
# Set TV_DISABLE=true to eliminate auth-timeout noise from tvDatafeed entirely.
# TV_DISABLE=true
#
# Fallback/Legacy credentials (may trigger CAPTCHA blocks):
# TV_USERNAME=your_tradingview_username
# TV_PASSWORD=your_tradingview_password

# ── Dashboard Authentication (HTTP Basic Auth) ─────────────────────────────
# Credentials required to access /broker and /settings pages on the dashboard.
# Defaults to 'admin' / 'admin' if left blank.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=admin

# ── AI Product Enrichment (Google Gemini / OpenAI / Groq / OpenRouter) ──────────────────────────────────
# Required for LLM Trade Verdict integration.
# OPENAI_API_KEY=your_openai_api_key
# GEMINI_API_KEY=your_gemini_api_key
# GROQ_API_KEY=your_groq_api_key
# OPENROUTER_API_KEY=your_openrouter_api_key

# ── Paytm Money Credentials ───────────────────────────────────────────
# Option 1: Use JWT token directly (expires ~26 days)
# Get from: https://developer.paytmmoney.com → authorize → copy request_token
# Then run: python tools/generate_paytm_token.py <request_token>
PAYTM_JWT_TOKEN=your_paytm_jwt_token

# Option 2: Enable auto-JWT refresh with headless authentication
# Add your Paytm email and password for automatic token refresh when expired
# PAYTM_EMAIL=your_email@example.com
# PAYTM_PASSWORD=your_password

PAYTM_API_KEY=your_paytm_api_key
PAYTM_API_SECRET=your_paytm_api_secret
