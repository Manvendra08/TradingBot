
# Environment variables for NSEBOT
# Copy this to .env and fill in your values.
# Load with: pip install python-dotenv  →  from dotenv import load_dotenv; load_dotenv()
# Or set in your system environment before running.

# ── Dhan ───────────────────────────────────────────────────────────────────
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# ── Upstox ─────────────────────────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=your_upstox_access_token

# ── Telegram ───────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather → get BOT_TOKEN
# 2. Send a message to your bot, then call:
#    https://api.telegram.org/bot<BOT_TOKEN>/getUpdates  → find chat_id
TELEGRAM_BOT_TOKEN=7187419055:AAGddBOIjEUyVT6UAAvqbY1CSGOxnBFKReY
TELEGRAM_CHAT_ID=938043948

# ── TradingView (required for MCX commodity chart data via tvDatafeed) ──────
# Since automated username/password login frequently triggers CAPTCHAs, it is highly
# recommended to use your browser sessionid cookie instead (bypasses CAPTCHA).
# Without this or credentials, MCX chart fetch (NATURALGAS/CRUDEOIL) will fail.
#
# To get your sessionid cookie:
# 1. Log in to tradingview.com in your browser.
# 2. Right-click anywhere -> Inspect -> Application (tab) -> Cookies -> https://www.tradingview.com.
# 3. Copy the value of the cookie named 'sessionid'.
TV_SESSIONID=your_tradingview_sessionid_cookie

# Fallback/Legacy credentials (might trigger CAPTCHA block):
TV_USERNAME=your_tradingview_username
TV_PASSWORD=your_tradingview_password

# ── Dashboard Authentication (HTTP Basic Auth) ─────────────────────────────
# Credentials required to access /broker and /settings pages on the dashboard.
# Defaults to 'admin' / 'admin' if left blank.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

